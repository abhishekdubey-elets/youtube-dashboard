# ============================================================================
# elets YouTube Transcript Automation Dashboard — Environment Configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# --- General ---------------------------------------------------------------
ENVIRONMENT=development                # development | staging | production
PROJECT_NAME="elets Transcript Dashboard"
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO

# --- Security / Auth -------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Bootstrap admin user (created on first startup if it does not exist)
FIRST_ADMIN_EMAIL=admin@elets.in
FIRST_ADMIN_PASSWORD=ChangeMe123!

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=elets
POSTGRES_PASSWORD=elets_password
POSTGRES_DB=elets_transcripts
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# SQLAlchemy URL (async). Overrides the discrete vars above if set.
DATABASE_URL=postgresql+asyncpg://elets:elets_password@postgres:5432/elets_transcripts
# Sync URL used by Alembic + Celery
DATABASE_URL_SYNC=postgresql+psycopg2://elets:elets_password@postgres:5432/elets_transcripts

# --- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Storage ---------------------------------------------------------------
STORAGE_DIR=/data/storage          # where downloaded audio is written
DELETE_AUDIO_AFTER_PROCESSING=true
MAX_AUDIO_AGE_HOURS=24

# --- YouTube ---------------------------------------------------------------
# Optional: cookies file path to access age-restricted / members content
YTDLP_COOKIES_FILE=
YTDLP_MAX_PLAYLIST_ITEMS=200

# --- Transcription ---------------------------------------------------------
# Provider selection: openai_whisper | local_whisper | deepgram
TRANSCRIPTION_PROVIDER=openai_whisper
TRANSCRIPTION_LANGUAGE=                 # blank = auto-detect

# OpenAI (Whisper API + Summaries)
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
# Summarization model (e.g. gpt-4.1, gpt-5)
OPENAI_SUMMARY_MODEL=gpt-4.1
OPENAI_SUMMARY_TEMPERATURE=0.2

# Local Whisper (faster-whisper)
LOCAL_WHISPER_MODEL=large-v3
LOCAL_WHISPER_DEVICE=auto               # auto | cpu | cuda
LOCAL_WHISPER_COMPUTE_TYPE=auto

# Deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# --- Google Sheets ---------------------------------------------------------
# Path to the service-account JSON (uploaded via the UI or mounted)
GOOGLE_CREDENTIALS_FILE=/data/secrets/google-credentials.json
GOOGLE_SHEET_ID=
GOOGLE_WORKSHEET_NAME=Transcripts
GOOGLE_SHEETS_AUTO_EXPORT=false

# --- Processing ------------------------------------------------------------
MAX_RETRIES=3
TASK_TIMEOUT_SECONDS=3600
